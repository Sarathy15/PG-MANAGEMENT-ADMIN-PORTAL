{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://pg-management-admin-portal.onrender.com/api/v1/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/login.html"
    },
    {
      "source": "/(css|js|assets|components)/:path*",
      "destination": "/frontend/$1/$2"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/:path*"
    }
  ]
}
